#!/usr/bin/env bash
set -euo pipefail

root=$(cd "$(dirname "$0")" && pwd)
repo_root=$(cd "$root/../.." && pwd)
repo_lock="/tmp/nexus-workflow-${repo_root//\//_}.lock"
if [[ ${NEXUS_ROOT_LOCK_HELD:-0} != 1 ]]; then
    exec 8>"$repo_lock"
    flock 8
fi
# shellcheck source=scripts/qemu-stream-capture.sh
source "$root/scripts/qemu-stream-capture.sh"
lock_key=$(printf '%s' "$root" | sha256sum | cut -c1-16)
exec 9>"/tmp/nexus-ostd-virtio-cser-spike-$lock_key.lock"
flock 9
image_key=$(sha256sum \
    "$root/Dockerfile" \
    "$root/.dockerignore" \
    "$root/Cargo.toml" \
    "$root/Cargo.lock" \
    "$root/OSDK.toml" \
    "$root/rust-toolchain.toml" \
    "$root/LICENSE-MPL-2.0" \
    "$root/src/lib.rs" \
    "$root/assets/sector0.txt" \
    "$root/scripts/assert-patch.sh" \
    "$root/scripts/check-facade-boundary.sh" \
    "$root/scripts/check-io-gate.sh" \
    "$root/scripts/assert-serial.sh" \
    "$root/scripts/assert-debug-trace.awk" \
    "$root/scripts/assert-stream-capture.sh" \
    "$root/scripts/qemu-stream-capture.sh" \
    "$root/osdk-runner-base/Cargo.toml" \
    "$root/osdk-runner-base/Cargo.lock" \
    "$root/osdk-runner-base/src/main.rs" \
    "$root/osdk-runner-base/x86_64.ld" \
    "$root/osdk-runner-base/riscv64.ld" \
    "$root/osdk-runner-base/loongarch64.ld" \
    "$repo_root/crates/cser-transition-gates/Cargo.toml" \
    "$repo_root/crates/cser-transition-gates/src/lib.rs" \
    "$repo_root/crates/cser-transition-gates/src/oneshot.rs" \
    "$repo_root/crates/cser-transition-gates/src/deadline.rs" \
    "$repo_root/crates/cser-transition-gates/src/scheduler.rs" \
    "$repo_root/crates/cser-transition-gates/src/pager.rs" \
    "$repo_root/crates/cser-transition-gates/src/io.rs" \
    "$repo_root/crates/nexus-ostd-virtio/Cargo.toml" \
    "$repo_root/crates/nexus-ostd-virtio/Cargo.lock" \
    "$repo_root/crates/nexus-ostd-virtio/README.md" \
    "$repo_root/crates/nexus-ostd-virtio/src/lib.rs" \
    "$repo_root/crates/nexus-ostd-virtio/src/dma.rs" \
    "$repo_root/crates/nexus-ostd-virtio/src/pci.rs" \
    "$repo_root/crates/nexus-ostd-virtio/src/portal.rs" \
    "$repo_root/crates/nexus-ostd-virtio/src/production.rs" \
    "$repo_root/patches/ostd-0.18.0-cser.patch" \
    "$repo_root/patches/virtio-drivers-0.13.0-cser.patch" \
    "$repo_root/patches/virtio-drivers-0.13.0-LICENSE-MIT" \
    "$repo_root/patches/cser-cargo-config.toml" \
    "$repo_root/tools/ostd/assert-cser-patch.sh" \
    "$repo_root/tools/virtio/assert-cser-patch.sh" \
    "$repo_root/tools/virtio/assert-production-substrate.sh" \
    "$repo_root/kernel/nexus-ostd/Cargo.toml" \
    "$repo_root/kernel/nexus-ostd/Cargo.lock" \
    "$repo_root/kernel/nexus-ostd/src/cser/effect_registry.rs" \
    "$repo_root/kernel/nexus-ostd/src/cser/device_flight.rs" | cut -d ' ' -f1 | sha256sum | cut -c1-16)
image="nexus/ostd-virtio-cser-spike:$image_key"
runner_base="$root/osdk-runner-base"
runner_target="$root/target/osdk/ostd-virtio-cser-spike-run-base"

build_image() {
    local -a rebuild_args=()
    if [[ ${NEXUS_REBUILD:-0} == 1 ]]; then
        rebuild_args=(--no-cache)
    fi
    docker build \
        "${rebuild_args[@]}" \
        --build-context "nexus-root=$repo_root" \
        --platform linux/amd64 \
        -t "$image" \
        "$root"
}

container() {
    docker run --rm \
        --init \
        --platform linux/amd64 \
        --network none \
        --user "$(id -u):$(id -g)" \
        --env HOME=/tmp/nexus-home \
        --tmpfs /tmp/nexus-home:rw,exec,nosuid,size=64m,mode=1777 \
        -v "$root:/work:z" \
        -v "$repo_root:/repo:ro,z" \
        -v "$repo_root/crates/cser-transition-gates:/crates/cser-transition-gates:ro,z" \
        -v "$repo_root/crates/nexus-ostd-virtio:/crates/nexus-ostd-virtio:ro,z" \
        --mount "type=bind,source=$repo_root/kernel/nexus-ostd/Cargo.toml,target=/kernel/nexus-ostd/Cargo.toml,readonly" \
        --mount "type=bind,source=$repo_root/kernel/nexus-ostd/Cargo.lock,target=/kernel/nexus-ostd/Cargo.lock,readonly" \
        --mount "type=bind,source=$repo_root/kernel/nexus-ostd/src/cser/effect_registry.rs,target=/kernel/nexus-ostd/src/cser/effect_registry.rs,readonly" \
        --mount "type=bind,source=$repo_root/kernel/nexus-ostd/src/cser/device_flight.rs,target=/kernel/nexus-ostd/src/cser/device_flight.rs,readonly" \
        --mount "type=bind,source=$root/Cargo.lock,target=/work/Cargo.lock,readonly" \
        -w /work \
        "$image" \
        "$@"
}

ensure_image() {
    if [[ ${NEXUS_REBUILD:-0} == 1 ]] || ! docker image inspect "$image" >/dev/null 2>&1; then
        build_image
    fi
}

check_source() {
    container bash scripts/assert-patch.sh
    container bash scripts/check-facade-boundary.sh
    container bash scripts/check-io-gate.sh
    container bash -c '
        set -euo pipefail
        tmp=$(mktemp -d)
        trap '\''rm -rf "$tmp"'\'' EXIT
        portal_source=/crates/nexus-ostd-virtio/src/portal.rs
        require_mutation() {
            if cmp -s "$1" "$2"; then
                echo "source mutation did not apply: $3" >&2
                exit 1
            fi
        }

        cp /repo/patches/ostd-0.18.0-cser.patch "$tmp/mutated-ostd.patch"
        sed -i '\''0,/const RTE_LEVEL_TRIGGERED: u32 = 1 << 15;/s//const RTE_LEVEL_TRIGGERED: u32 = 1 << 14;/'\'' \
            "$tmp/mutated-ostd.patch"
        if /repo/tools/ostd/assert-cser-patch.sh \
            "$tmp/mutated-ostd.patch" /opt/nexus-ostd/ostd-0.18.0 >/dev/null 2>&1; then
            echo "canonical OSTD gate accepted a polarity/trigger patch mutation" >&2
            exit 1
        fi

        cp -a /opt/nexus-ostd/ostd-0.18.0 "$tmp/mutated-ostd"
        sed -i '\''s/const RTE_LEVEL_TRIGGERED: u32 = 1 << 15;/const RTE_LEVEL_TRIGGERED: u32 = 1 << 14;/'\'' \
            "$tmp/mutated-ostd/src/arch/x86/irq/chip/ioapic.rs"
        if /repo/tools/ostd/assert-cser-patch.sh \
            /repo/patches/ostd-0.18.0-cser.patch "$tmp/mutated-ostd" >/dev/null 2>&1; then
            echo "canonical OSTD gate accepted a mutated installed source tree" >&2
            exit 1
        fi

        canonical_virtio=/repo/patches/virtio-drivers-0.13.0-cser.patch
        virtio_license=/repo/patches/virtio-drivers-0.13.0-LICENSE-MIT
        installed_virtio=/opt/nexus-virtio/virtio-drivers-0.13.0
        production=/crates/nexus-ostd-virtio/src/production.rs
        facade_lib=/crates/nexus-ostd-virtio/src/lib.rs
        pci_source=/crates/nexus-ostd-virtio/src/pci.rs
        check_production_substrate() {
            /repo/tools/virtio/assert-production-substrate.sh \
                "$1" "$facade_lib" "$portal_source" "$pci_source"
        }

        cp "$canonical_virtio" "$tmp/relaxed-virtio.patch"
        sed -i '\''0,/Ordering::Release/s//Ordering::Relaxed/'\'' \
            "$tmp/relaxed-virtio.patch"
        if /repo/tools/virtio/assert-cser-patch.sh \
            "$tmp/relaxed-virtio.patch" "$installed_virtio" "$virtio_license" \
            >/dev/null 2>&1; then
            echo "canonical VirtIO gate accepted Release-to-Relaxed mutation" >&2
            exit 1
        fi

        cp -a "$installed_virtio" "$tmp/missing-linear-owner"
        sed -i '\''0,/queue: ManuallyDrop<VirtQueue<H, SIZE>>,/s//queue: VirtQueue<H, SIZE>,/'\'' \
            "$tmp/missing-linear-owner/src/queue.rs"
        if /repo/tools/virtio/assert-cser-patch.sh \
            "$canonical_virtio" "$tmp/missing-linear-owner" "$virtio_license" \
            >/dev/null 2>&1; then
            echo "canonical VirtIO gate accepted missing ManuallyDrop owner" >&2
            exit 1
        fi

        cp -a "$installed_virtio" "$tmp/missing-recycle"
        sed -i '\''s/self.recycle_descriptors(head, inputs, outputs);/let _ = (head, inputs, outputs);/'\'' \
            "$tmp/missing-recycle/src/queue.rs"
        if /repo/tools/virtio/assert-cser-patch.sh \
            "$canonical_virtio" "$tmp/missing-recycle" "$virtio_license" \
            >/dev/null 2>&1; then
            echo "canonical VirtIO gate accepted missing exact-buffer recycle" >&2
            exit 1
        fi

        cp "$production" "$tmp/facade-authority.rs"
        sed -i '\''2i use crate::EffectAuthority;'\'' "$tmp/facade-authority.rs"
        if check_production_substrate "$tmp/facade-authority.rs" >/dev/null 2>&1; then
            echo "production facade gate accepted semantic authority ownership" >&2
            exit 1
        fi

        cp "$production" "$tmp/post-release-assert.rs"
        sed -i '\''/let (queue, _token) = prepared.publish_prepared();/a\        assert!(true);'\'' \
            "$tmp/post-release-assert.rs"
        if check_production_substrate "$tmp/post-release-assert.rs" >/dev/null 2>&1; then
            echo "production facade gate accepted a post-Release assertion" >&2
            exit 1
        fi

        cp "$production" "$tmp/branching-generation.rs"
        sed -i '\''s/\*self.device_generation = self.next_generation;/if true { *self.device_generation = self.next_generation; }/'\'' \
            "$tmp/branching-generation.rs"
        if check_production_substrate "$tmp/branching-generation.rs" >/dev/null 2>&1; then
            echo "production facade gate accepted branching generation apply" >&2
            exit 1
        fi

        cp "$production" "$tmp/branching-quiescence.rs"
        sed -i '\''s/\*self.active = None;/if true { *self.active = None; }/'\'' \
            "$tmp/branching-quiescence.rs"
        if check_production_substrate "$tmp/branching-quiescence.rs" >/dev/null 2>&1; then
            echo "production facade gate accepted branching quiescence apply" >&2
            exit 1
        fi

        cp "$production" "$tmp/overlapping-session.rs"
        sed -i '\''0,/if self.active.is_some() {/s//if false {/'\'' \
            "$tmp/overlapping-session.rs"
        require_mutation "$production" "$tmp/overlapping-session.rs" overlapping-session
        if check_production_substrate "$tmp/overlapping-session.rs" >/dev/null 2>&1; then
            echo "production facade gate accepted overlapping hardware sessions" >&2
            exit 1
        fi

        cp "$production" "$tmp/forced-notification.rs"
        sed -i '\''0,/if self.queue.as_ref().expect("live queue").should_notify() {/s//if true {/'\'' \
            "$tmp/forced-notification.rs"
        require_mutation "$production" "$tmp/forced-notification.rs" forced-notification
        if check_production_substrate "$tmp/forced-notification.rs" >/dev/null 2>&1; then
            echo "production facade gate accepted mandatory notification despite suppression" >&2
            exit 1
        fi

        cp "$production" "$tmp/unchecked-used-length.rs"
        sed -i '\''0,/if used_len != EXPECTED_USED_LEN {/s//if false {/'\'' \
            "$tmp/unchecked-used-length.rs"
        require_mutation "$production" "$tmp/unchecked-used-length.rs" unchecked-used-length
        if check_production_substrate "$tmp/unchecked-used-length.rs" >/dev/null 2>&1; then
            echo "production facade gate accepted an unchecked device used length" >&2
            exit 1
        fi

        cp "$production" "$tmp/status-before-used-length.rs"
        sed -i '\''0,/if used_len != EXPECTED_USED_LEN {/i\        let response = request_buffers.response.status();'\'' \
            "$tmp/status-before-used-length.rs"
        require_mutation "$production" "$tmp/status-before-used-length.rs" status-before-used-length
        if check_production_substrate "$tmp/status-before-used-length.rs" >/dev/null 2>&1; then
            echo "production facade gate accepted status access before used-length validation" >&2
            exit 1
        fi

        cp "$portal_source" "$tmp/missing-gate.rs"
        sed -i '\''/gate: IoGate<4>,/d'\'' "$tmp/missing-gate.rs"
        if bash scripts/check-io-gate.sh "$tmp/missing-gate.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted a missing shared gate" >&2
            exit 1
        fi

        cp "$portal_source" "$tmp/missing-commit.rs"
        sed -i '\''s/\.commit_with(authority/.commit_without_gate(authority/'\'' \
            "$tmp/missing-commit.rs"
        if bash scripts/check-io-gate.sh "$tmp/missing-commit.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted a missing commit gate" >&2
            exit 1
        fi

        cp "$portal_source" "$tmp/missing-instance-namespace.rs"
        sed -i '\''s/IoGate::new(instance_id)/IoGate::new(1)/'\'' \
            "$tmp/missing-instance-namespace.rs"
        if bash scripts/check-io-gate.sh "$tmp/missing-instance-namespace.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted an unbound gate instance namespace" >&2
            exit 1
        fi

        cp "$portal_source" "$tmp/missing-session-instance-binding.rs"
        sed -i '\''s/authority\.instance_id() != self\.gate\.instance_id()/self.gate.instance_id() == 0/'\'' \
            "$tmp/missing-session-instance-binding.rs"
        if bash scripts/check-io-gate.sh "$tmp/missing-session-instance-binding.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted a foreign authority for another Session BDF" >&2
            exit 1
        fi

        cp src/lib.rs "$tmp/missing-session-negative-call.rs"
        sed -i '\''/let namespace_isolation = assert_session_namespace_isolation();/d'\'' \
            "$tmp/missing-session-negative-call.rs"
        if bash scripts/check-io-gate.sh "$portal_source" "$tmp/missing-session-negative-call.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted a marker without executing the namespace negative" >&2
            exit 1
        fi

        cp src/lib.rs "$tmp/late-session-negative-call.rs"
        sed -i '\''/let namespace_isolation = assert_session_namespace_isolation();/d'\'' \
            "$tmp/late-session-negative-call.rs"
        sed -i '\''/println!("{}", namespace_isolation.into_marker());/d'\'' \
            "$tmp/late-session-negative-call.rs"
        sed -i '\''/let mut root = discover_and_own_bars();/a\    let namespace_isolation = assert_session_namespace_isolation();\n    println!("{}", namespace_isolation.into_marker());'\'' \
            "$tmp/late-session-negative-call.rs"
        if bash scripts/check-io-gate.sh "$portal_source" "$tmp/late-session-negative-call.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted the namespace negative after PCI/DMA discovery" >&2
            exit 1
        fi

        cp src/lib.rs "$tmp/conditional-session-negative-call.rs"
        sed -i '\''/let namespace_isolation = assert_session_namespace_isolation();/i\    if false {'\'' \
            "$tmp/conditional-session-negative-call.rs"
        sed -i '\''/println!("{}", namespace_isolation.into_marker());/a\    }'\'' \
            "$tmp/conditional-session-negative-call.rs"
        if bash scripts/check-io-gate.sh "$portal_source" "$tmp/conditional-session-negative-call.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted a conditionally skipped namespace negative" >&2
            exit 1
        fi

        cp src/lib.rs "$tmp/fabricated-session-negative-marker.rs"
        sed -i '\''s/println!("{}", namespace_isolation.into_marker());/println!("IO Namespace foreign_bdf_rejected=true bidirectional=true portal_state_unchanged=true pre_pci_dma=true");/'\'' \
            "$tmp/fabricated-session-negative-marker.rs"
        if bash scripts/check-io-gate.sh "$portal_source" "$tmp/fabricated-session-negative-marker.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted a caller-fabricated namespace marker" >&2
            exit 1
        fi

        cp "$portal_source" "$tmp/copied-gate-probe.rs"
        sed -i '\''s/self\.gate\.can_complete_device(authority)/{ let mut probe = self.gate; probe.complete_device(authority).is_ok() }/'\'' \
            "$tmp/copied-gate-probe.rs"
        if bash scripts/check-io-gate.sh "$tmp/copied-gate-probe.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted a copied gate probe" >&2
            exit 1
        fi

        cp "$portal_source" "$tmp/shadow-epoch.rs"
        sed -i '\''/pub struct Portal {/a\    authority_epoch: u64,'\'' \
            "$tmp/shadow-epoch.rs"
        if bash scripts/check-io-gate.sh "$tmp/shadow-epoch.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted a shadow authority epoch" >&2
            exit 1
        fi
        echo "Stage 7B I/O gate negative assertions: PASS virtio_release_relaxed=rejected virtio_missing_linear_owner=rejected virtio_missing_recycle=rejected facade_authority=rejected facade_post_release_assert=rejected facade_branching_generation=rejected facade_branching_quiescence=rejected facade_overlapping_session=rejected facade_forced_notification=rejected facade_unchecked_used_length=rejected facade_status_before_used_length=rejected missing_gate=rejected missing_commit_gate=rejected missing_instance_namespace=rejected missing_session_instance_binding=rejected missing_session_negative_execution=rejected late_session_negative_execution=rejected conditional_session_negative_execution=rejected fabricated_session_marker=rejected copied_gate_probe=rejected shadow_epoch=rejected"
    '
}

check_oracles() {
    container bash -c '
        set -euo pipefail
        shopt -s nullglob
        oracles=(scripts/*.awk)
        ((${#oracles[@]} > 0))
        for oracle in "${oracles[@]}"; do
            awk -W dump -f "$oracle" >/dev/null
        done
    '
}

check_kernel() {
    # cargo-osdk 0.18 does not expose --locked on build/run. Gate the project
    # lock explicitly and over-mount it read-only for all mounted builds.
    container cargo fmt --all -- --check
    container cargo fmt --manifest-path /crates/nexus-ostd-virtio/Cargo.toml -- --check
    container env CARGO_TARGET_DIR=/work/target/facade-check \
        cargo check --manifest-path /crates/nexus-ostd-virtio/Cargo.toml \
        --locked --target x86_64-unknown-none
    container cargo osdk check --locked
    # cargo-osdk 0.18 has no clippy subcommand. Run the no_std library directly;
    # the upstream macro emits a private `ktest` cfg and this typestate API
    # intentionally returns the retained tombstone as the large Err value.
    container cargo clippy --locked --target x86_64-unknown-none --lib -- \
        -D warnings \
        -A unexpected_cfgs \
        -A clippy::result_large_err
}

format_kernel() {
    container cargo fmt --all
}

doctor() {
    ensure_image
    check_stream_capture
    check_source
    container bash -c '
        set -eu
        rustc --version
        cargo --version
        cargo osdk --version
        test -r /root/ovmf/release/OVMF_CODE.fd
        test -x /usr/local/qemu/bin/qemu-system-x86_64
    '
    echo 'DOCTOR VIRTIO PASS network=offline iommu_patch=audited qemu=true ovmf=true'
}

prepare_runner_base() {
    rm -rf "$runner_target"
    mkdir -p "$(dirname "$runner_target")"
    cp -a "$runner_base" "$runner_target"
    chmod a-w "$runner_target/Cargo.lock"
}

assert_runner_base() {
    diff -ru "$runner_base" "$runner_target"
}

build_kernel() {
    check_source
    check_kernel
    prepare_runner_base
    container cargo osdk build
    assert_runner_base
}

run_kernel() {
    build_kernel
    container bash -c '
        set -u
        cp /root/ovmf/release/OVMF_VARS.fd "$HOME/OVMF_VARS.fd"
        expected=27a4e8fed7b428b42ff04e3f62eadfe2e3f3310dac4e2fe8ecfff04be3cca254
        before=$(sha256sum /opt/nexus-fixtures/sector0.raw | cut -d " " -f1)
        set +e
        timeout --signal=TERM --kill-after=2s 30s cargo osdk run
        status=$?
        set -e
        after=$(sha256sum /opt/nexus-fixtures/sector0.raw | cut -d " " -f1)
        echo "FIXTURE Hash before=$before after=$after readonly=true"
        test "$before" = "$expected"
        test "$after" = "$expected"
        exit "$status"
    '
    assert_runner_base
}

extract_kernel_suffix() {
    local source=$1
    local target=$2
    awk '
        /VIRTIO_CSER KERNEL_MARKER stage=5b oracle_suffix=true/ { found = 1 }
        found { gsub(/\r/, ""); print }
        END { if (!found) exit 1 }
    ' "$source" > "$target"
}

check_stream_capture() {
    bash "$root/scripts/assert-stream-capture.sh"
}

capture_kernel_run() {
    capture_qemu_streams \
        "$root/artifacts/serial.log" \
        "$root/artifacts/qemu-debug.log" \
        run_kernel
    echo 'QEMU_CAPTURE PASS profile=stage5b live_replay=false serial=artifacts/serial.log debug=artifacts/qemu-debug.log'
}

command=${1:-test}
case "$command" in
    doctor)
        doctor
        ;;
    image)
        build_image
        ;;
    fmt)
        ensure_image
        format_kernel
        ;;
    source)
        ensure_image
        check_source
        ;;
    check)
        ensure_image
        check_stream_capture
        check_source
        check_oracles
        check_kernel
        ;;
    build)
        ensure_image
        build_kernel
        ;;
    run)
        ensure_image
        mkdir -p "$root/artifacts"
        rm -f \
            "$root/artifacts/serial.log" \
            "$root/artifacts/qemu-debug.log" \
            "$root/artifacts/qemu.log" \
            "$root/artifacts/kernel.log" \
            "$root/artifacts/oracle.log"
        capture_kernel_run
        extract_kernel_suffix "$root/artifacts/serial.log" "$root/artifacts/kernel.log"
        ;;
    test)
        ensure_image
        check_stream_capture
        mkdir -p "$root/artifacts"
        rm -f \
            "$root/artifacts/serial.log" \
            "$root/artifacts/qemu-debug.log" \
            "$root/artifacts/qemu.log" \
            "$root/artifacts/kernel.log" \
            "$root/artifacts/oracle.log"
        capture_kernel_run
        extract_kernel_suffix "$root/artifacts/serial.log" "$root/artifacts/kernel.log"
        "$root/scripts/assert-serial.sh" \
            "$root/artifacts/kernel.log" \
            "$root/artifacts/qemu-debug.log" 2>&1 \
            | tee "$root/artifacts/oracle.log"
        ;;
    clean)
        rm -rf "$root/target" "$root/artifacts" "$root/patch-work"
        ;;
    *)
        echo 'usage: ./x {doctor|image|fmt|source|check|build|run|test|clean}' >&2
        exit 2
        ;;
esac

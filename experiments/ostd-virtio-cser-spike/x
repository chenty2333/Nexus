#!/usr/bin/env bash
set -euo pipefail

root=$(cd "$(dirname "$0")" && pwd)
repo_root=$(cd "$root/../.." && pwd)
repo_lock="/tmp/nexus-workflow-${repo_root//\//_}.lock"
if [[ ${NEXUS_ROOT_LOCK_HELD:-0} != 1 ]]; then
    exec 8>"$repo_lock"
    flock 8
fi
# shellcheck source=scripts/qemu-stream-capture.sh
source "$root/scripts/qemu-stream-capture.sh"
lock_key=$(printf '%s' "$root" | sha256sum | cut -c1-16)
exec 9>"/tmp/nexus-ostd-virtio-cser-spike-$lock_key.lock"
flock 9
image_key=$(sha256sum \
    "$root/Dockerfile" \
    "$root/.dockerignore" \
    "$root/Cargo.toml" \
    "$root/Cargo.lock" \
    "$root/OSDK.toml" \
    "$root/rust-toolchain.toml" \
    "$root/cargo-home-config.toml" \
    "$root/LICENSE-MPL-2.0" \
    "$root/src/lib.rs" \
    "$root/src/dma.rs" \
    "$root/src/pci.rs" \
    "$root/src/portal.rs" \
    "$root/assets/sector0.txt" \
    "$root/patches/ostd-0.18.0-dma-closure.patch" \
    "$root/scripts/assert-patch.sh" \
    "$root/scripts/check-io-gate.sh" \
    "$root/scripts/assert-serial.sh" \
    "$root/scripts/assert-debug-trace.awk" \
    "$root/scripts/assert-stream-capture.sh" \
    "$root/scripts/qemu-stream-capture.sh" \
    "$root/osdk-runner-base/Cargo.toml" \
    "$root/osdk-runner-base/Cargo.lock" \
    "$root/osdk-runner-base/src/main.rs" \
    "$root/osdk-runner-base/x86_64.ld" \
    "$root/osdk-runner-base/riscv64.ld" \
    "$root/osdk-runner-base/loongarch64.ld" \
    "$repo_root/crates/cser-transition-gates/Cargo.toml" \
    "$repo_root/crates/cser-transition-gates/src/lib.rs" \
    "$repo_root/crates/cser-transition-gates/src/oneshot.rs" \
    "$repo_root/crates/cser-transition-gates/src/deadline.rs" \
    "$repo_root/crates/cser-transition-gates/src/scheduler.rs" \
    "$repo_root/crates/cser-transition-gates/src/pager.rs" \
    "$repo_root/crates/cser-transition-gates/src/io.rs" \
    "$repo_root/kernel/nexus-ostd/src/cser/effect_registry.rs" | cut -d ' ' -f1 | sha256sum | cut -c1-16)
image="nexus/ostd-virtio-cser-spike:$image_key"
runner_base="$root/osdk-runner-base"
runner_target="$root/target/osdk/ostd-virtio-cser-spike-run-base"

build_image() {
    docker build \
        --build-context "nexus-root=$repo_root" \
        --platform linux/amd64 \
        -t "$image" \
        "$root"
}

container() {
    docker run --rm \
        --platform linux/amd64 \
        --network none \
        --user "$(id -u):$(id -g)" \
        --env HOME=/tmp/nexus-home \
        --tmpfs /tmp/nexus-home:rw,exec,nosuid,size=64m,mode=1777 \
        -v "$root:/work:z" \
        -v "$repo_root/crates/cser-transition-gates:/crates/cser-transition-gates:ro,z" \
        --mount "type=bind,source=$repo_root/kernel/nexus-ostd/src/cser/effect_registry.rs,target=/kernel/nexus-ostd/src/cser/effect_registry.rs,readonly" \
        --mount "type=bind,source=$root/Cargo.lock,target=/work/Cargo.lock,readonly" \
        -w /work \
        "$image" \
        "$@"
}

ensure_image() {
    if [[ ${NEXUS_REBUILD:-0} == 1 ]] || ! docker image inspect "$image" >/dev/null 2>&1; then
        build_image
    fi
}

check_source() {
    container bash scripts/assert-patch.sh
    container bash scripts/check-io-gate.sh
    container bash -c '
        set -euo pipefail
        tmp=$(mktemp -d)
        trap '\''rm -rf "$tmp"'\'' EXIT

        cp src/portal.rs "$tmp/missing-gate.rs"
        sed -i '\''/gate: IoGate<4>,/d'\'' "$tmp/missing-gate.rs"
        if bash scripts/check-io-gate.sh "$tmp/missing-gate.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted a missing shared gate" >&2
            exit 1
        fi

        cp src/portal.rs "$tmp/missing-commit.rs"
        sed -i '\''s/\.commit_with(authority/.commit_without_gate(authority/'\'' \
            "$tmp/missing-commit.rs"
        if bash scripts/check-io-gate.sh "$tmp/missing-commit.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted a missing commit gate" >&2
            exit 1
        fi

        cp src/portal.rs "$tmp/missing-instance-namespace.rs"
        sed -i '\''s/IoGate::new(instance_id)/IoGate::new(1)/'\'' \
            "$tmp/missing-instance-namespace.rs"
        if bash scripts/check-io-gate.sh "$tmp/missing-instance-namespace.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted an unbound gate instance namespace" >&2
            exit 1
        fi

        cp src/portal.rs "$tmp/missing-session-instance-binding.rs"
        sed -i '\''s/authority\.instance_id() != self\.gate\.instance_id()/self.gate.instance_id() == 0/'\'' \
            "$tmp/missing-session-instance-binding.rs"
        if bash scripts/check-io-gate.sh "$tmp/missing-session-instance-binding.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted a foreign authority for another Session BDF" >&2
            exit 1
        fi

        cp src/lib.rs "$tmp/missing-session-negative-call.rs"
        sed -i '\''/let namespace_isolation = portal::assert_session_namespace_isolation();/d'\'' \
            "$tmp/missing-session-negative-call.rs"
        if bash scripts/check-io-gate.sh src/portal.rs "$tmp/missing-session-negative-call.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted a marker without executing the namespace negative" >&2
            exit 1
        fi

        cp src/lib.rs "$tmp/late-session-negative-call.rs"
        sed -i '\''/let namespace_isolation = portal::assert_session_namespace_isolation();/d'\'' \
            "$tmp/late-session-negative-call.rs"
        sed -i '\''/println!("{}", namespace_isolation.into_marker());/d'\'' \
            "$tmp/late-session-negative-call.rs"
        sed -i '\''/let (mut root, device_function, memory_bars) = pci::discover_and_own_bars();/a\    let namespace_isolation = portal::assert_session_namespace_isolation();\n    println!("{}", namespace_isolation.into_marker());'\'' \
            "$tmp/late-session-negative-call.rs"
        if bash scripts/check-io-gate.sh src/portal.rs "$tmp/late-session-negative-call.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted the namespace negative after PCI/DMA discovery" >&2
            exit 1
        fi

        cp src/lib.rs "$tmp/conditional-session-negative-call.rs"
        sed -i '\''/let namespace_isolation = portal::assert_session_namespace_isolation();/i\    if false {'\'' \
            "$tmp/conditional-session-negative-call.rs"
        sed -i '\''/println!("{}", namespace_isolation.into_marker());/a\    }'\'' \
            "$tmp/conditional-session-negative-call.rs"
        if bash scripts/check-io-gate.sh src/portal.rs "$tmp/conditional-session-negative-call.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted a conditionally skipped namespace negative" >&2
            exit 1
        fi

        cp src/lib.rs "$tmp/fabricated-session-negative-marker.rs"
        sed -i '\''s/println!("{}", namespace_isolation.into_marker());/println!("IO Namespace foreign_bdf_rejected=true bidirectional=true portal_state_unchanged=true pre_pci_dma=true");/'\'' \
            "$tmp/fabricated-session-negative-marker.rs"
        if bash scripts/check-io-gate.sh src/portal.rs "$tmp/fabricated-session-negative-marker.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted a caller-fabricated namespace marker" >&2
            exit 1
        fi

        cp src/portal.rs "$tmp/copied-gate-probe.rs"
        sed -i '\''s/self\.gate\.can_complete_device(authority)/{ let mut probe = self.gate; probe.complete_device(authority).is_ok() }/'\'' \
            "$tmp/copied-gate-probe.rs"
        if bash scripts/check-io-gate.sh "$tmp/copied-gate-probe.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted a copied gate probe" >&2
            exit 1
        fi

        cp src/portal.rs "$tmp/shadow-epoch.rs"
        sed -i '\''/pub struct Portal {/a\    authority_epoch: u64,'\'' \
            "$tmp/shadow-epoch.rs"
        if bash scripts/check-io-gate.sh "$tmp/shadow-epoch.rs" >/dev/null 2>&1; then
            echo "I/O adapter oracle accepted a shadow authority epoch" >&2
            exit 1
        fi
        echo "Stage 7B I/O gate negative assertions: PASS missing_gate=rejected missing_commit_gate=rejected missing_instance_namespace=rejected missing_session_instance_binding=rejected missing_session_negative_execution=rejected late_session_negative_execution=rejected conditional_session_negative_execution=rejected fabricated_session_marker=rejected copied_gate_probe=rejected shadow_epoch=rejected"
    '
}

check_oracles() {
    container bash -c '
        set -euo pipefail
        shopt -s nullglob
        oracles=(scripts/*.awk)
        ((${#oracles[@]} > 0))
        for oracle in "${oracles[@]}"; do
            awk -W dump -f "$oracle" >/dev/null
        done
    '
}

check_kernel() {
    # cargo-osdk 0.18 does not expose --locked on build/run. Gate the project
    # lock explicitly and over-mount it read-only for all mounted builds.
    container cargo fmt --all -- --check
    container cargo osdk check --locked
    # cargo-osdk 0.18 has no clippy subcommand. Run the no_std library directly;
    # the upstream macro emits a private `ktest` cfg and this typestate API
    # intentionally returns the retained tombstone as the large Err value.
    container cargo clippy --locked --target x86_64-unknown-none --lib -- \
        -D warnings \
        -A unexpected_cfgs \
        -A clippy::result_large_err
}

format_kernel() {
    container cargo fmt --all
}

doctor() {
    ensure_image
    check_stream_capture
    check_source
    container bash -c '
        set -eu
        rustc --version
        cargo --version
        cargo osdk --version
        test -r /root/ovmf/release/OVMF_CODE.fd
        test -x /usr/local/qemu/bin/qemu-system-x86_64
    '
    echo 'DOCTOR VIRTIO PASS network=offline iommu_patch=audited qemu=true ovmf=true'
}

prepare_runner_base() {
    rm -rf "$runner_target"
    mkdir -p "$(dirname "$runner_target")"
    cp -a "$runner_base" "$runner_target"
    chmod a-w "$runner_target/Cargo.lock"
}

assert_runner_base() {
    diff -ru "$runner_base" "$runner_target"
}

build_kernel() {
    check_source
    check_kernel
    prepare_runner_base
    container cargo osdk build
    assert_runner_base
}

run_kernel() {
    build_kernel
    container bash -c '
        set -u
        cp /root/ovmf/release/OVMF_VARS.fd "$HOME/OVMF_VARS.fd"
        expected=27a4e8fed7b428b42ff04e3f62eadfe2e3f3310dac4e2fe8ecfff04be3cca254
        before=$(sha256sum /opt/nexus-fixtures/sector0.raw | cut -d " " -f1)
        set +e
        timeout --signal=TERM --kill-after=2s 30s cargo osdk run
        status=$?
        set -e
        after=$(sha256sum /opt/nexus-fixtures/sector0.raw | cut -d " " -f1)
        echo "FIXTURE Hash before=$before after=$after readonly=true"
        test "$before" = "$expected"
        test "$after" = "$expected"
        exit "$status"
    '
    assert_runner_base
}

extract_kernel_suffix() {
    local source=$1
    local target=$2
    awk '
        /VIRTIO_CSER KERNEL_MARKER stage=5b oracle_suffix=true/ { found = 1 }
        found { gsub(/\r/, ""); print }
        END { if (!found) exit 1 }
    ' "$source" > "$target"
}

check_stream_capture() {
    bash "$root/scripts/assert-stream-capture.sh"
}

capture_kernel_run() {
    capture_qemu_streams \
        "$root/artifacts/serial.log" \
        "$root/artifacts/qemu-debug.log" \
        run_kernel
}

command=${1:-test}
case "$command" in
    doctor)
        doctor
        ;;
    image)
        build_image
        ;;
    fmt)
        ensure_image
        format_kernel
        ;;
    source)
        ensure_image
        check_source
        ;;
    check)
        ensure_image
        check_stream_capture
        check_source
        check_oracles
        check_kernel
        ;;
    build)
        ensure_image
        build_kernel
        ;;
    run)
        ensure_image
        mkdir -p "$root/artifacts"
        rm -f \
            "$root/artifacts/serial.log" \
            "$root/artifacts/qemu-debug.log" \
            "$root/artifacts/qemu.log" \
            "$root/artifacts/kernel.log" \
            "$root/artifacts/oracle.log"
        capture_kernel_run
        extract_kernel_suffix "$root/artifacts/serial.log" "$root/artifacts/kernel.log"
        ;;
    test)
        ensure_image
        check_stream_capture
        mkdir -p "$root/artifacts"
        rm -f \
            "$root/artifacts/serial.log" \
            "$root/artifacts/qemu-debug.log" \
            "$root/artifacts/qemu.log" \
            "$root/artifacts/kernel.log" \
            "$root/artifacts/oracle.log"
        capture_kernel_run
        extract_kernel_suffix "$root/artifacts/serial.log" "$root/artifacts/kernel.log"
        "$root/scripts/assert-serial.sh" \
            "$root/artifacts/kernel.log" \
            "$root/artifacts/qemu-debug.log" 2>&1 \
            | tee "$root/artifacts/oracle.log"
        ;;
    clean)
        rm -rf "$root/target" "$root/artifacts" "$root/patch-work"
        ;;
    *)
        echo 'usage: ./x {doctor|image|fmt|source|check|build|run|test|clean}' >&2
        exit 2
        ;;
esac

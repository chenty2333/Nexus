+    // Prevent same-CPU synchronous interrupt-remapping re-entry between slot
+    // reservation and descriptor submission. This guard covers exactly one
+    // PTE removal and never a hardware-completion wait.
+    let _irq_guard = irq::disable_local();
+    let ticket = {
+        let mut regs = IOMMU_REGS.get().unwrap().lock();
+        regs.reap_completed_invalidation();
+        if !regs.invalidation_slot_available() {
+            return Err(BeginIotlbInvalidationError::Busy);
+        }
+        regs.reserve_dma_invalidation()

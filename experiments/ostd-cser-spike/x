#!/usr/bin/env bash
set -euo pipefail

root=$(cd "$(dirname "$0")" && pwd)
repo_root=$(cd "$root/../.." && pwd)
image_key=$(sha256sum \
    "$root/Dockerfile" \
    "$root/.dockerignore" \
    "$repo_root/.dockerignore" \
    "$repo_root/tests/guest/linux/sources/linux-hello/hello.S" \
    "$root/Cargo.toml" \
    "$root/Cargo.lock" \
    "$root/OSDK.toml" \
    "$root/rust-toolchain.toml" \
    "$root/osdk-runner-base/Cargo.toml" \
    "$root/osdk-runner-base/Cargo.lock" \
    "$root/osdk-runner-base/src/main.rs" \
    "$root/osdk-runner-base/x86_64.ld" \
    "$root/osdk-runner-base/riscv64.ld" \
    "$root/osdk-runner-base/loongarch64.ld" \
    "$root/scripts/build-guest.sh" \
    "$root/guest/linux-futex-shared.S" \
    "$root/guest/linux-futex-personality-v1.S" \
    "$root/guest/linux-futex-personality-v2.S" \
    "$root/userspace/personality/.cargo/config.toml" \
    "$root/userspace/personality/Cargo.toml" \
    "$root/userspace/personality/Cargo.lock" \
    "$root/userspace/personality/linker.ld" \
    "$root/userspace/personality/src/bin/v1.rs" \
    "$root/userspace/personality/src/bin/v2.rs" | cut -d ' ' -f1 | sha256sum | cut -c1-16)
image="nexus/ostd-cser-spike:$image_key"
runner_base="$root/osdk-runner-base"
runner_target="$root/target/osdk/ostd-cser-spike-run-base"

build_image() {
    docker build \
        --platform linux/amd64 \
        --file "$root/Dockerfile" \
        --tag "$image" \
        "$repo_root"
}

container() {
    docker run --rm \
        --platform linux/amd64 \
        --network none \
        --user "$(id -u):$(id -g)" \
        --env HOME=/tmp/nexus-home \
        --tmpfs /tmp/nexus-home:rw,exec,nosuid,size=64m,mode=1777 \
        -v "$root:/work:z" \
        -v "$repo_root:/repo:ro,z" \
        --mount "type=bind,source=$root/Cargo.lock,target=/work/Cargo.lock,readonly" \
        --mount "type=bind,source=$root/userspace/personality/Cargo.lock,target=/work/userspace/personality/Cargo.lock,readonly" \
        -w /work \
        "$image" \
        "$@"
}

ensure_image() {
    if [[ ${NEXUS_REBUILD:-0} == 1 ]] || ! docker image inspect "$image" >/dev/null 2>&1; then
        build_image
    fi
}

prepare_guest() {
    container bash scripts/build-guest.sh
}

check_kernel() {
    # cargo-osdk 0.18 does not expose --locked on build/run. Gate the project
    # lockfile explicitly before every build; it is also over-mounted read-only
    # so build/run cannot rewrite it. The separate generated runner graph is
    # fixed by the committed osdk-runner-base snapshot below.
    container cargo osdk check --locked
}

prepare_runner_base() {
    rm -rf "$runner_target"
    mkdir -p "$(dirname "$runner_target")"
    cp -a "$runner_base" "$runner_target"
    # Fail at the attempted rewrite, not merely at the post-build diff, if
    # cargo-osdk stops reusing this exact Run base.
    chmod a-w "$runner_target/Cargo.lock"
}

assert_runner_base() {
    diff -ru "$runner_base" "$runner_target"
}

build_kernel() {
    check_kernel
    prepare_runner_base
    container cargo osdk build
    assert_runner_base
}

run_kernel() {
    # Keep compilation outside the runtime deadline. On a cold CI worker the
    # OSDK wrapper and ISO build can consume nearly all of 30 seconds before
    # QEMU starts, which would turn a build-time variance into a false runtime
    # timeout.
    build_kernel
    container bash -c '
        cp /root/ovmf/release/OVMF_VARS.fd "$HOME/OVMF_VARS.fd"
        exec timeout --signal=TERM --kill-after=2s 30s cargo osdk run
    '
    assert_runner_base
}

command=${1:-test}
case "$command" in
    image)
        build_image
        ;;
    check)
        ensure_image
        prepare_guest
        check_kernel
        ;;
    build)
        ensure_image
        prepare_guest
        build_kernel
        ;;
    iommu-probe)
        ensure_image
        container bash scripts/check-iotlb-gap.sh
        ;;
    run)
        ensure_image
        prepare_guest
        mkdir -p "$root/artifacts"
        run_kernel | tee "$root/artifacts/serial.log"
        ;;
    test)
        ensure_image
        prepare_guest
        mkdir -p "$root/artifacts"
        container bash scripts/check-iotlb-gap.sh
        run_kernel | tee "$root/artifacts/serial.log"
        "$root/scripts/assert-serial.sh" "$root/artifacts/serial.log"
        ;;
    clean)
        # Do not make cleanup depend on Docker or on a prebuilt image.
        rm -rf "$root/target" "$root/artifacts" "$root/userspace/personality/target"
        rm -f "$root"/guest/*.bin "$root"/guest/*.elf
        ;;
    *)
        echo "usage: ./x {image|check|build|iommu-probe|run|test|clean}" >&2
        exit 2
        ;;
esac

+/// A descriptor chain whose buffers and available-ring slot are initialized,
+/// but whose available index has not been published to the device.
+///
+/// This type owns the exact queue that created the chain. It is deliberately
+/// neither `Clone` nor `Copy`, so callers must choose exactly one of
+/// [`publish_prepared`](Self::publish_prepared) and
+/// [`cancel_prepared`](Self::cancel_prepared). Dropping it without making that
+/// choice violates the buffer-lifetime contract of [`VirtQueue::prepare_add`].
+#[must_use = "a prepared descriptor chain must be published or cancelled"]
+#[derive(Debug)]
+pub struct PreparedVirtQueue<H: Hal, const SIZE: usize> {
+    queue: ManuallyDrop<VirtQueue<H, SIZE>>,
+    head: u16,
+}
+
+impl<H: Hal, const SIZE: usize> PreparedVirtQueue<H, SIZE> {
+    /// Returns the descriptor-head token reserved for this chain.
+    pub const fn token(&self) -> u16 {
+        self.head
+    }
+
+    /// Release-publishes the already initialized chain and returns its queue
+    /// together with the descriptor-head token.
+    ///
+    /// This operation is infallible because ownership of this value proves that
+    /// descriptor allocation, DMA sharing, and the available-ring slot write
+    /// have already completed for the enclosed queue.
+    pub fn publish_prepared(self) -> (VirtQueue<H, SIZE>, u16) {
+        let mut this = ManuallyDrop::new(self);
+        // SAFETY: `this` suppresses `PreparedVirtQueue::drop`, and this is the
+        // only explicit path that extracts the enclosed queue.
+        let mut queue = unsafe { ManuallyDrop::take(&mut this.queue) };
+        queue.publish_prepared_in_place();
+        (queue, this.head)
+    }
+
+    /// Cancels an unpublished chain and returns its queue for reuse.
+    ///
+    /// # Safety
+    ///
+    /// `inputs` and `outputs` must be the exact live buffers passed to
+    /// [`VirtQueue::prepare_add`] for this value. No caller may access or drop
+    /// those buffers until this function returns.
+    pub unsafe fn cancel_prepared<'a>(
+        self,
+        inputs: &'a [&'a [u8]],
+        outputs: &'a mut [&'a mut [u8]],
+    ) -> VirtQueue<H, SIZE> {
+        // SAFETY: forwarded from the caller under the original prepare
+        // contract. The available index was never advanced, so the device
+        // cannot have observed this chain.
+        let mut this = ManuallyDrop::new(self);
+        // SAFETY: `this` suppresses `PreparedVirtQueue::drop`, and this is the
+        // only explicit cancellation path that extracts the enclosed queue.
+        let mut queue = unsafe { ManuallyDrop::take(&mut this.queue) };
+        // SAFETY: forwarded from the caller under the exact original prepare
+        // contract, and the device-visible available index is unchanged.
+        unsafe { queue.cancel_prepared_in_place(this.head, inputs, outputs) };
+        queue
+    }
+}
+
+impl<H: Hal, const SIZE: usize> Drop for PreparedVirtQueue<H, SIZE> {
+    fn drop(&mut self) {
+        // Fail closed: an unresolved prepared chain retains its queue DMA and
+        // shared buffers. Only explicit publish or cancellation may extract
+        // the queue and discharge the original buffer-lifetime obligation.
+    }
+}
+
+/// A failed prepare operation that returns ownership of the unchanged queue.
+#[must_use = "recover the queue from a failed prepare operation"]
+#[derive(Debug)]
+pub struct PrepareAddError<H: Hal, const SIZE: usize> {
+    error: Error,
+    queue: VirtQueue<H, SIZE>,
+}
+
+impl<H: Hal, const SIZE: usize> PrepareAddError<H, SIZE> {
+    /// Returns the original validation error.
+    pub const fn error(&self) -> Error {
+        self.error
+    }
+
+    /// Returns the unchanged queue and consumes this error.
+    pub fn into_queue(self) -> VirtQueue<H, SIZE> {
+        self.queue
+    }
+}

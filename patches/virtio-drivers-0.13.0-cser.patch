+    fn prepare_is_invisible_until_publish() {
+        {
+            let _guard = VALIDATION_TEST_LOCK.lock().unwrap();
+            reset_validation_counts();
+            let queue = validation_queue();
+            let before = validation_snapshot(&queue);
+
+            // SAFETY: there are no buffers to retain on this validation failure.
+            let error = unsafe { queue.prepare_add(&[], &mut []) }.unwrap_err();
+            assert_eq!(error.error(), Error::InvalidParam);
+            let queue = error.into_queue();
+            assert_eq!(validation_snapshot(&queue), before);
+
+            let input = [42_u8];
+            // SAFETY: input remains live until the exact cancellation below.
+            let prepared = unsafe { queue.prepare_add(&[&input], &mut []) }.unwrap();
+            // SAFETY: this is the exact input used by prepare_add.
+            let queue = unsafe { prepared.cancel_prepared(&[&input], &mut []) };
+            assert_eq!(queue.available_desc(), 4);
+            assert_eq!(queue.avail_idx, 0);
+            assert_eq!(VALIDATION_SHARE_CALLS.load(Ordering::SeqCst), 1);
+            assert_eq!(VALIDATION_UNSHARE_CALLS.load(Ordering::SeqCst), 1);
+        }

+            max_queue_size: 4,
+            device_features: 0,
+            state,
+        };
+        let queue = VirtQueue::<FakeHal, 4>::new(&mut transport, 0, false, false).unwrap();
+        let input = [42_u8];
+        let mut output = [0_u8; 1];
+        // SAFETY: both buffers remain live and inaccessible until the matching
+        // publish and pop below.
+        let prepared = unsafe { queue.prepare_add(&[&input], &mut [&mut output]) }.unwrap();
+        let token = prepared.token();
+        assert_eq!(token, 0);
+        assert_eq!(prepared.queue.available_desc(), 2);
+        assert_eq!(
+            unsafe { (*prepared.queue.avail.as_ptr()).idx.load(Ordering::Acquire) },
+            0
+        );
+        assert!(!fake_read_write_queue::<4>(
+            prepared.queue.desc.as_ptr().cast(),
+            prepared.queue.avail.as_ptr().cast(),
+            prepared.queue.used.as_ptr().cast(),
+            |_| vec![7],
+        ));
+
+        let (mut queue, published) = prepared.publish_prepared();
+        assert_eq!(published, token);
+        assert_eq!(
+            unsafe { (*queue.avail.as_ptr()).idx.load(Ordering::Acquire) },
+            1
+        );
+        assert!(fake_read_write_queue::<4>(

    echo 'QEMU_CAPTURE PASS profile=runtime-fs-same-boot live_replay=false serial=artifacts/runtime-fs-same-boot/serial.log debug=artifacts/runtime-fs-same-boot/qemu-debug.log'
}

run_same_boot_precommit_kernel() {
    # Match the positive same-boot run's single-attempt hosted-TCG headroom.
    build_same_boot_precommit_kernel
    container bash -c '
        set -euo pipefail
        readonly fixture=/opt/nexus-fixtures/runtime-fs-block.raw
        readonly expected=9357413ed9a96a23af1750cc304265dd7dd1835eb58eb1fb50119cd80d0bc8ca
        cp /root/ovmf/release/OVMF_VARS.fd "$HOME/OVMF_VARS.fd"
        before=$(sha256sum "$fixture" | cut -d " " -f1)
        before_mode=$(stat -c %a "$fixture")
        test "$before" = "$expected"
        test "$before_mode" = 444
        set +e
        timeout --signal=TERM --kill-after=2s 90s \
            cargo osdk run --scheme runtime-fs-same-boot-precommit
        status=$?
        set -e
        after=$(sha256sum "$fixture" | cut -d " " -f1)
        after_mode=$(stat -c %a "$fixture")
        test "$after" = "$expected"
        test "$after_mode" = 444
        echo "RUNTIME_FS_SAME_BOOT_PRECOMMIT_FIXTURE before=$before after=$after mode=$after_mode readonly=true"
        exit "$status"
    '
    assert_runner_base
}


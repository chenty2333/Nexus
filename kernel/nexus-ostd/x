build_stage7b() {
    check_kernel
    prepare_runner_base
    container cargo osdk build --release --features stage7b-eval
    assert_runner_base
}

first_allowed_cpu() {
    local allowed first
    allowed=$(awk '$1 == "Cpus_allowed_list:" { print $2 }' /proc/self/status)
    first=${allowed%%,*}
    first=${first%%-*}
    if [[ ! $first =~ ^[0-9]+$ ]]; then
        echo "cannot select first CPU from Cpus_allowed_list=$allowed" >&2
        return 1
    fi
    printf '%s\n' "$first"
}

run_stage7b_kernel() {
    local cpu=$1
    NEXUS_CONTAINER_CPUSET=$cpu container bash -c '
        set -euo pipefail
        cp /root/ovmf/release/OVMF_VARS.fd "$HOME/OVMF_VARS.fd"
        exec timeout --signal=TERM --kill-after=2s 180s \
            cargo osdk run --release --features stage7b-eval
    '
}

eval_stage7b() {
    # Build the release evaluator before the runtime deadline. The run command
    # reuses this exact generated image and runner graph.
    build_stage7b
    local allowed cpu metadata temporary serial debug status
    allowed=$(awk '$1 == "Cpus_allowed_list:" { print $2 }' /proc/self/status)
    cpu=$(first_allowed_cpu)
    mkdir -p "$root/artifacts"
    serial="$root/artifacts/stage7b-evaluation.log"
    debug="$root/artifacts/stage7b-qemu-debug.log"
    metadata="$root/artifacts/stage7b-runtime-metadata.env"
    temporary="$metadata.tmp.$$"
    rm -f "$serial" "$debug" "$metadata" "$temporary"
    {
        echo 'schema=nexus.stage7b.runtime-metadata.v1'
        echo 'accel=tcg'
        echo 'vcpus=1'
        echo 'threads=1'
        echo "cpu_pin=$cpu"
        echo "cpus_allowed_list=$allowed"
    } >"$temporary"
    mv "$temporary" "$metadata"

    # shellcheck source=scripts/qemu-stream-capture.sh
    source "$capture_helper"
    set +e
    capture_qemu_streams "$serial" "$debug" run_stage7b_kernel "$cpu"
    status=$?
    set -e
    assert_runner_base
    if (( status != 0 )); then
        echo "Stage 7B evaluator failed with status $status" >&2
        return "$status"
    fi
    rm -f "$standard_debugcon_scratch"
    tr -d '\r' <"$serial" \
        | grep -Fx 'STAGE7B_EVALUATION PASS faults=20 scale_points=14 performance_cases=29' \
            >/dev/null
    echo "STAGE7B QEMU PASS cpu_pin=$cpu accel=tcg threads=1 vcpus=1 profile=release"
}


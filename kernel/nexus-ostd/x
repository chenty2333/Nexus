        "$repo_root/patches/ostd-0.18.0-cser.patch" \
        "$repo_root/patches/virtio-drivers-0.13.0-cser.patch" \
        "$repo_root/patches/virtio-drivers-0.13.0-LICENSE-MIT" \
        "$repo_root/patches/cser-cargo-config.toml" \
        "$repo_root/tools/ostd/assert-cser-patch.sh" \

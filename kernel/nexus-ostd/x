check_kernel() {
    # cargo-osdk 0.18 does not expose --locked on build/run. Gate the project
    # lockfile explicitly before every build; it is also over-mounted read-only
    # so build/run cannot rewrite it. The separate generated runner graph is
    # fixed by the committed osdk-runner-base snapshot below.
    container cargo check --locked --offline --target x86_64-unknown-none \
        --features virtio-cser-facade
    container cargo osdk check --locked
}

clippy_all() {
    # cargo-osdk 0.18 has no Clippy subcommand. The kernel library can still
    # be checked directly for its declared bare-metal target after the guest
    # artifacts used by include_bytes! have been prepared.
    container cargo clippy \
        --locked \
        --offline \
        --target x86_64-unknown-none \
        -- \
        -D warnings
    container cargo clippy \
        --manifest-path userspace/personality/Cargo.toml \
        --target x86_64-unknown-none \
        --release \
        --locked \
        --offline \
        -- \
        -D warnings
}

prepare_runner_base() {
    rm -rf "$runner_target"
    mkdir -p "$(dirname "$runner_target")"
    cp -a "$runner_base" "$runner_target"
    # Fail at the attempted rewrite, not merely at the post-build diff, if
    # cargo-osdk stops reusing this exact Run base.
    chmod a-w "$runner_target/Cargo.lock"
}

assert_runner_base() {
    diff -ru "$runner_base" "$runner_target"
}

build_kernel() {
    check_kernel
    prepare_runner_base
    container cargo osdk build
    assert_runner_base
}

build_same_boot_kernel() {
    check_kernel
    prepare_runner_base
    container cargo osdk build --scheme runtime-fs-same-boot
    assert_runner_base
}

build_same_boot_precommit_kernel() {
    check_kernel
    container cargo check --locked --offline --target x86_64-unknown-none \
        --features virtio-cser-precommit-fault
    prepare_runner_base
    container cargo osdk build --scheme runtime-fs-same-boot-precommit
    assert_runner_base
}

run_kernel() {
    # Keep compilation outside the runtime deadline. On a cold CI worker the
    # OSDK wrapper and ISO build can consume nearly all of 30 seconds before
    # QEMU starts, which would turn a build-time variance into a false runtime
    # timeout.
    build_kernel
    container bash -c '
        cp /root/ovmf/release/OVMF_VARS.fd "$HOME/OVMF_VARS.fd"
        exec timeout --signal=TERM --kill-after=2s 30s cargo osdk run
    '
    assert_runner_base
}


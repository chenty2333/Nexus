        "$repo_root/crates/nexus-ostd-virtio/src/production.rs" \
        "$root/scripts/check-scheduler-attempt.sh"; do
        if [[ ! -f $input ]]; then
            echo "nexus-ostd doctor: missing pinned input: $input" >&2
            return 1
        fi
    done
    ensure_image
    check_ostd_patch
    check_virtio_patch
    container bash -c '
        set -euo pipefail
        command -v rustc >/dev/null
        command -v cargo >/dev/null

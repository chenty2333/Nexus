run_same_boot_kernel() {
    # Keep compilation outside the runtime deadline and verify the immutable
    # block fixture on both sides of the QEMU execution. Hosted TCG can exhibit
    # long scheduler-to-user-entry tails on shared CI workers, so retain one
    # non-retried run but give the runtime 90 seconds of diagnostic headroom.
    build_same_boot_kernel
    container bash -c '
        set -euo pipefail
        readonly fixture=/opt/nexus-fixtures/runtime-fs-block.raw
        readonly expected=9357413ed9a96a23af1750cc304265dd7dd1835eb58eb1fb50119cd80d0bc8ca
        cp /root/ovmf/release/OVMF_VARS.fd "$HOME/OVMF_VARS.fd"
        before=$(sha256sum "$fixture" | cut -d " " -f1)
        before_mode=$(stat -c %a "$fixture")
        test "$before" = "$expected"
        test "$before_mode" = 444
        set +e
        timeout --signal=TERM --kill-after=2s 90s \
            cargo osdk run --scheme runtime-fs-same-boot
        status=$?
        set -e
        after=$(sha256sum "$fixture" | cut -d " " -f1)
        after_mode=$(stat -c %a "$fixture")
        test "$after" = "$expected"
        test "$after_mode" = 444
        echo "RUNTIME_FS_SAME_BOOT_FIXTURE before=$before after=$after mode=$after_mode readonly=true"
        exit "$status"
    '
    assert_runner_base
}


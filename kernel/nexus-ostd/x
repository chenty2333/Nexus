#!/usr/bin/env bash
set -euo pipefail

root=$(cd "$(dirname "$0")" && pwd)
repo_root=$(cd "$root/../.." && pwd)
repo_lock="/tmp/nexus-workflow-${repo_root//\//_}.lock"
kernel_lock="/tmp/nexus-kernel-${root//\//_}.lock"
if [[ ${NEXUS_ROOT_LOCK_HELD:-0} != 1 ]]; then
    exec 8>"$repo_lock"
    flock 8
fi
exec 9>"$kernel_lock"
flock 9
# Hash only inputs consumed while building the pinned image. Runtime serial
# oracles execute from the mounted worktree and must not force an image rebuild.
image_key=$(sha256sum \
    "$root/Dockerfile" \
    "$root/.dockerignore" \
    "$repo_root/.dockerignore" \
    "$repo_root/tests/guest/linux/sources/linux-hello/hello.S" \
    "$repo_root/tests/guest/linux/sources/linux-dynamic-pie-smoke/dynamic_pie_smoke.S" \
    "$repo_root/tests/guest/linux/sources/linux-dynamic-pie-main/dynamic_pie_main.c" \
    "$repo_root/tests/guest/linux/sources/linux-dynamic-runtime-interp/dynamic_runtime_interp.c" \
    "$repo_root/tests/guest/linux/sources/linux-round4-futex-smoke/round4_futex_smoke.S" \
    "$repo_root/tests/guest/linux/adaptations/round4-futex-modern-requeue.patch" \
    "$repo_root/tests/guest/linux/sources/linux-round5-epoll-smoke/round5_epoll_smoke.S" \
    "$repo_root/tests/guest/linux/adaptations/round5-epoll-linux-regular-file.patch" \
    "$repo_root/tests/guest/linux/adaptations/verify-round5-epoll-adaptation.sh" \
    "$repo_root/tests/guest/linux/sources/linux-runtime-fs-smoke/runtime_fs_smoke.S" \
    "$repo_root/tests/guest/linux/sources/linux-runtime-net-smoke/runtime_net_smoke.S" \
    "$root/Cargo.toml" \
    "$root/Cargo.lock" \
    "$root/OSDK.toml" \
    "$root/rust-toolchain.toml" \
    "$root/osdk-runner-base/Cargo.toml" \
    "$root/osdk-runner-base/Cargo.lock" \
    "$root/osdk-runner-base/src/main.rs" \
    "$root/osdk-runner-base/x86_64.ld" \
    "$root/osdk-runner-base/riscv64.ld" \
    "$root/osdk-runner-base/loongarch64.ld" \
    "$root/scripts/build-guest.sh" \
    "$root/scripts/assert-linux-elf.sh" \
    "$root/scripts/assert-dynamic-pie-artifacts.sh" \
    "$root/scripts/check-fsbase-api.sh" \
    "$root/scripts/check-scheduler-attempt.sh" \
    "$root/scripts/build-round4.sh" \
    "$root/scripts/build-round5.sh" \
    "$root/scripts/build-runtime-fs.sh" \

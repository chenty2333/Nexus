            >/dev/null 2>&1; then
            echo "runtime network build accepted wrong expected digest" >&2
            exit 1
        fi
        if [[ -e $tmp/wrong-digest.elf ]]; then
            echo "runtime network build published an artifact after digest failure" >&2
            exit 1
        fi

        cp guest/linux-runtime-net.elf "$tmp/preserved.elf"

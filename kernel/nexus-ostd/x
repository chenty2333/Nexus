image="nexus/nexus-ostd:$image_key"
runner_base="$root/osdk-runner-base"
runner_target="$root/target/osdk/nexus-kernel-run-base"

build_image() {
    local -a rebuild_args=()
    if [[ ${NEXUS_REBUILD:-0} == 1 ]]; then
        rebuild_args=(--no-cache)
    fi
    command "$docker_bin" build \
        "${rebuild_args[@]}" \
        --platform linux/amd64 \
        --file "$root/Dockerfile" \
        --tag "$image" \
        "$repo_root"
}

container() {
    local -a cpu_args=()
    if [[ -n ${NEXUS_CONTAINER_CPUSET:-} ]]; then
        cpu_args=(--cpuset-cpus "$NEXUS_CONTAINER_CPUSET")
    fi
    command "$docker_bin" run --rm \
        --init \
        "${cpu_args[@]}" \
        --platform linux/amd64 \
        --network none \
        --user "$(id -u):$(id -g)" \
        --env HOME=/tmp/nexus-home \
        --tmpfs /tmp/nexus-home:rw,exec,nosuid,size=64m,mode=1777 \
        -v "$root:/work:z" \
        -v "$repo_root:/repo:ro,z" \
        -v "$repo_root/crates/cser-transition-gates:/crates/cser-transition-gates:ro,z" \
        -v "$repo_root/crates/nexus-ostd-virtio:/crates/nexus-ostd-virtio:ro,z" \
        -v "$repo_root/crates/nexus-portal-abi:/crates/nexus-portal-abi:ro,z" \
        "${cser_source_mount_args[@]}" \
        --mount "type=bind,source=$root/Cargo.lock,target=/work/Cargo.lock,readonly" \
        --mount "type=bind,source=$root/userspace/personality/Cargo.lock,target=/work/userspace/personality/Cargo.lock,readonly" \
        -w /work \
        "$image" \
        "$@"
}

ensure_image() {
    if [[ ${NEXUS_REBUILD:-0} == 1 ]] \
        || ! command "$docker_bin" image inspect "$image" >/dev/null 2>&1; then
        build_image
    fi
}

check_ostd_patch() {
    container /repo/tools/ostd/assert-cser-patch.sh \
        /repo/patches/ostd-0.18.0-cser.patch \
        /opt/nexus-ostd/ostd-0.18.0
    container bash -c '
        set -euo pipefail
        tmp=$(mktemp -d)
        trap '\''rm -rf "$tmp"'\'' EXIT

        cp /repo/patches/ostd-0.18.0-cser.patch "$tmp/mutated.patch"
        sed -i '\''0,/const RTE_LEVEL_TRIGGERED: u32 = 1 << 15;/s//const RTE_LEVEL_TRIGGERED: u32 = 1 << 14;/'\'' \
            "$tmp/mutated.patch"
        if /repo/tools/ostd/assert-cser-patch.sh \
            "$tmp/mutated.patch" /opt/nexus-ostd/ostd-0.18.0 >/dev/null 2>&1; then
            echo "kernel OSTD gate accepted a mutated canonical patch" >&2
            exit 1
        fi

        cp -a /opt/nexus-ostd/ostd-0.18.0 "$tmp/mutated-source"
        sed -i '\''s/const RTE_ACTIVE_LOW: u32 = 1 << 13;/const RTE_ACTIVE_LOW: u32 = 1 << 12;/'\'' \
            "$tmp/mutated-source/src/arch/x86/irq/chip/ioapic.rs"
        if /repo/tools/ostd/assert-cser-patch.sh \
            /repo/patches/ostd-0.18.0-cser.patch "$tmp/mutated-source" >/dev/null 2>&1; then
            echo "kernel OSTD gate accepted a mutated installed source tree" >&2
            exit 1
        fi
        echo "canonical OSTD negative assertions: PASS patch_mutation=rejected source_mutation=rejected"
    '
}

check_virtio_patch() {
    container /repo/tools/virtio/assert-cser-patch.sh \
        /repo/patches/virtio-drivers-0.13.0-cser.patch \
        /opt/nexus-virtio/virtio-drivers-0.13.0 \
        /repo/patches/virtio-drivers-0.13.0-LICENSE-MIT
    container /repo/tools/virtio/assert-production-substrate.sh \
        /crates/nexus-ostd-virtio/src/production.rs \
        /crates/nexus-ostd-virtio/src/lib.rs \
        /crates/nexus-ostd-virtio/src/portal.rs \
        /crates/nexus-ostd-virtio/src/pci.rs
    container bash -c '
        set -euo pipefail
        tmp=$(mktemp -d)
        trap '\''rm -rf "$tmp"'\'' EXIT
        require_mutation() {
            if cmp -s "$1" "$2"; then
                echo "source mutation did not apply: $3" >&2
                exit 1
            fi
        }
        canonical=/repo/patches/virtio-drivers-0.13.0-cser.patch
        license=/repo/patches/virtio-drivers-0.13.0-LICENSE-MIT
        installed=/opt/nexus-virtio/virtio-drivers-0.13.0
        source=/crates/nexus-ostd-virtio/src/production.rs
        lib=/crates/nexus-ostd-virtio/src/lib.rs
        portal=/crates/nexus-ostd-virtio/src/portal.rs
        pci=/crates/nexus-ostd-virtio/src/pci.rs

        cp "$canonical" "$tmp/relaxed.patch"
        sed -i '\''0,/Ordering::Release/s//Ordering::Relaxed/'\'' "$tmp/relaxed.patch"
        if /repo/tools/virtio/assert-cser-patch.sh \
            "$tmp/relaxed.patch" "$installed" "$license" >/dev/null 2>&1; then
            echo "canonical VirtIO gate accepted Release-to-Relaxed mutation" >&2
            exit 1
        fi

        cp -a "$installed" "$tmp/missing-linear-owner"
        sed -i '\''0,/queue: ManuallyDrop<VirtQueue<H, SIZE>>,/s//queue: VirtQueue<H, SIZE>,/'\'' \
            "$tmp/missing-linear-owner/src/queue.rs"
        if /repo/tools/virtio/assert-cser-patch.sh \
            "$canonical" "$tmp/missing-linear-owner" "$license" >/dev/null 2>&1; then
            echo "canonical VirtIO gate accepted missing ManuallyDrop owner" >&2
            exit 1
        fi

        cp -a "$installed" "$tmp/missing-recycle"
        sed -i '\''s/self.recycle_descriptors(head, inputs, outputs);/let _ = (head, inputs, outputs);/'\'' \
            "$tmp/missing-recycle/src/queue.rs"
        if /repo/tools/virtio/assert-cser-patch.sh \
            "$canonical" "$tmp/missing-recycle" "$license" >/dev/null 2>&1; then
            echo "canonical VirtIO gate accepted missing exact-buffer recycle" >&2
            exit 1
        fi

        cp "$source" "$tmp/authority.rs"
        sed -i '\''2i use crate::EffectAuthority;'\'' "$tmp/authority.rs"
        if /repo/tools/virtio/assert-production-substrate.sh \
            "$tmp/authority.rs" "$lib" "$portal" >/dev/null 2>&1; then
            echo "production facade gate accepted semantic authority ownership" >&2
            exit 1
        fi

        cp "$source" "$tmp/post-release-assert.rs"
        sed -i '\''/let (queue, _token) = prepared.publish_prepared();/a\        assert!(true);'\'' \
            "$tmp/post-release-assert.rs"
        if /repo/tools/virtio/assert-production-substrate.sh \
            "$tmp/post-release-assert.rs" "$lib" "$portal" >/dev/null 2>&1; then
            echo "production facade gate accepted a post-Release assertion" >&2
            exit 1
        fi

        cp "$source" "$tmp/branching-generation.rs"
        sed -i '\''s/\*self.device_generation = self.next_generation;/if true { *self.device_generation = self.next_generation; }/'\'' \
            "$tmp/branching-generation.rs"
        if /repo/tools/virtio/assert-production-substrate.sh \
            "$tmp/branching-generation.rs" "$lib" "$portal" >/dev/null 2>&1; then
            echo "production facade gate accepted branching generation apply" >&2
            exit 1
        fi

        cp "$source" "$tmp/branching-quiescence.rs"
        sed -i '\''s/\*self.active = None;/if true { *self.active = None; }/'\'' \
            "$tmp/branching-quiescence.rs"
        if /repo/tools/virtio/assert-production-substrate.sh \
            "$tmp/branching-quiescence.rs" "$lib" "$portal" >/dev/null 2>&1; then
            echo "production facade gate accepted branching quiescence apply" >&2
            exit 1
        fi

        cp "$source" "$tmp/overlapping-session.rs"
        sed -i '\''0,/if self.active.is_some() {/s//if false {/'\'' \
            "$tmp/overlapping-session.rs"
        require_mutation "$source" "$tmp/overlapping-session.rs" overlapping-session
        if /repo/tools/virtio/assert-production-substrate.sh \
            "$tmp/overlapping-session.rs" "$lib" "$portal" >/dev/null 2>&1; then
            echo "production facade gate accepted overlapping hardware sessions" >&2
            exit 1
        fi

        cp "$source" "$tmp/forced-notification.rs"
        sed -i '\''0,/if self.queue.as_ref().expect("live queue").should_notify() {/s//if true {/'\'' \
            "$tmp/forced-notification.rs"
        require_mutation "$source" "$tmp/forced-notification.rs" forced-notification
        if /repo/tools/virtio/assert-production-substrate.sh \
            "$tmp/forced-notification.rs" "$lib" "$portal" >/dev/null 2>&1; then
            echo "production facade gate accepted mandatory notification despite suppression" >&2
            exit 1
        fi

        cp "$source" "$tmp/unchecked-used-length.rs"
        sed -i '\''0,/if used_len != EXPECTED_USED_LEN {/s//if false {/'\'' \
            "$tmp/unchecked-used-length.rs"
        require_mutation "$source" "$tmp/unchecked-used-length.rs" unchecked-used-length
        if /repo/tools/virtio/assert-production-substrate.sh \
            "$tmp/unchecked-used-length.rs" "$lib" "$portal" >/dev/null 2>&1; then
            echo "production facade gate accepted an unchecked device used length" >&2
            exit 1
        fi

        cp "$source" "$tmp/status-before-used-length.rs"
        sed -i '\''0,/if used_len != EXPECTED_USED_LEN {/i\        let response = request_buffers.response.status();'\'' \
            "$tmp/status-before-used-length.rs"
        require_mutation "$source" "$tmp/status-before-used-length.rs" status-before-used-length
        if /repo/tools/virtio/assert-production-substrate.sh \
            "$tmp/status-before-used-length.rs" "$lib" "$portal" >/dev/null 2>&1; then
            echo "production facade gate accepted status access before used-length validation" >&2
            exit 1
        fi

        cp "$source" "$tmp/irq-uses-polling-mode.rs"
        sed -i '\''0,/prepare_read_sector0_with_mode(root, CompletionMode::Interrupt)/s//prepare_read_sector0_with_mode(root, CompletionMode::Polling)/'\'' \
            "$tmp/irq-uses-polling-mode.rs"
        require_mutation "$source" "$tmp/irq-uses-polling-mode.rs" irq-uses-polling-mode
        if /repo/tools/virtio/assert-production-substrate.sh \
            "$tmp/irq-uses-polling-mode.rs" "$lib" "$portal" "$pci" >/dev/null 2>&1; then
            echo "production facade gate accepted IRQ preparation with polling notifications" >&2
            exit 1
        fi

        cp "$source" "$tmp/irq-ack-spins.rs"
        sed -i '\''/pub fn ack_interrupt(&mut self) -> InterruptReceipt {/a\        core::hint::spin_loop();'\'' \
            "$tmp/irq-ack-spins.rs"
        require_mutation "$source" "$tmp/irq-ack-spins.rs" irq-ack-spins
        if /repo/tools/virtio/assert-production-substrate.sh \
            "$tmp/irq-ack-spins.rs" "$lib" "$portal" "$pci" >/dev/null 2>&1; then
            echo "production facade gate accepted a spinning IRQ acknowledgement" >&2
            exit 1
        fi

        cp "$pci" "$tmp/cloneable-intx-token.rs"
        sed -i '\''0,/pub struct MaskedIntx {/s//#[derive(Clone)]\npub struct MaskedIntx {/'\'' \
            "$tmp/cloneable-intx-token.rs"
        require_mutation "$pci" "$tmp/cloneable-intx-token.rs" cloneable-intx-token
        if /repo/tools/virtio/assert-production-substrate.sh \
            "$source" "$lib" "$portal" "$tmp/cloneable-intx-token.rs" >/dev/null 2>&1; then
            echo "production facade gate accepted a cloneable INTx owner token" >&2
            exit 1
        fi

        cp "$pci" "$tmp/reclaim-intx.rs"
        sed -i '\''0,/if self.intx_state != IntxOwnershipState::Unclaimed {/s//if false {/'\'' \
            "$tmp/reclaim-intx.rs"
        require_mutation "$pci" "$tmp/reclaim-intx.rs" reclaim-intx
        if /repo/tools/virtio/assert-production-substrate.sh \
            "$source" "$lib" "$portal" "$tmp/reclaim-intx.rs" >/dev/null 2>&1; then
            echo "production facade gate accepted repeated initial INTx claims" >&2
            exit 1
        fi

        cp "$pci" "$tmp/intx-command-collateral.rs"
        sed -i '\''0,/command.union(Command::INTERRUPT_DISABLE)/s//command.union(Command::INTERRUPT_DISABLE).union(Command::BUS_MASTER)/'\'' \
            "$tmp/intx-command-collateral.rs"
        require_mutation "$pci" "$tmp/intx-command-collateral.rs" intx-command-collateral
        if /repo/tools/virtio/assert-production-substrate.sh \
            "$source" "$lib" "$portal" "$tmp/intx-command-collateral.rs" >/dev/null 2>&1; then
            echo "production facade gate accepted collateral PCI command mutation" >&2
            exit 1
        fi

        cp "$pci" "$tmp/intx-readback-forged.rs"
        sed -i '\''0,/let (_, observed) = root.inner.get_status_command(device_function);/s//let observed = expected;/'\'' \
            "$tmp/intx-readback-forged.rs"
        require_mutation "$pci" "$tmp/intx-readback-forged.rs" intx-readback-forged
        if /repo/tools/virtio/assert-production-substrate.sh \
            "$source" "$lib" "$portal" "$tmp/intx-readback-forged.rs" >/dev/null 2>&1; then
            echo "production facade gate accepted forged PCI command readback" >&2
            exit 1

set -euo pipefail

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
readonly PATH
root=$(cd "$(/usr/bin/dirname "$0")" && pwd)
repo_root=$(cd "$root/../.." && pwd)
docker_bin=/usr/bin/docker
if [[ ! -f $docker_bin || ! -x $docker_bin || -L $docker_bin ]] \
    || [[ $(/usr/bin/realpath -e -- "$docker_bin") != "$docker_bin" ]]; then
    echo "Docker CLI must be the non-symlink executable $docker_bin" >&2
    exit 1
fi
readonly docker_bin
capture_helper="$root/scripts/qemu-stream-capture.sh"
capture_helper_sha256=b05544fb66e5d124fb141696accb1933742de561469f1c9e4a12eef3c6c5e7b7
if [[ ! -f $capture_helper || -L $capture_helper ]] \
    || [[ $(/usr/bin/realpath -e -- "$capture_helper") != "$capture_helper" ]]; then
    echo "QEMU capture helper must be a non-symlink regular file: $capture_helper" >&2
    exit 1
fi
if [[ $(/usr/bin/sha256sum -- "$capture_helper" | /usr/bin/cut -d ' ' -f1) \
    != "$capture_helper_sha256" ]]; then
    echo "QEMU capture helper source drifted: $capture_helper" >&2
    exit 1
fi
readonly capture_helper capture_helper_sha256
repo_lock="/tmp/nexus-workflow-${repo_root//\//_}.lock"
kernel_lock="/tmp/nexus-kernel-${root//\//_}.lock"
if [[ ${NEXUS_ROOT_LOCK_HELD:-0} != 1 ]]; then
    exec 8>"$repo_lock"
    flock 8
fi
exec 9>"$kernel_lock"
flock 9
production_source_manifest="$root/cser-production-sources.txt"
if [[ ! -f $production_source_manifest || -L $production_source_manifest ]] \
    || [[ $(realpath -e -- "$production_source_manifest") != "$production_source_manifest" ]]; then
    echo "CSER production source manifest must be a non-symlink regular file: $production_source_manifest" >&2
    exit 1
fi
mapfile -t cser_production_sources <"$production_source_manifest"
declare -a cser_source_hash_inputs=()
declare -a cser_source_mount_args=()
previous_production_source=
for relative in "${cser_production_sources[@]}"; do
    if [[ ! $relative =~ ^[a-z0-9_./-]+\.rs$ ]] \
        || [[ $relative == /* || $relative == ./* || $relative == *"/./"* ]] \
        || [[ $relative == *".."* || $relative == *"//"* ]]; then
        echo "invalid CSER production source path: $relative" >&2
        exit 1
    fi
    if [[ -n $previous_production_source && ! $previous_production_source < $relative ]]; then
        echo "CSER production source manifest is not strictly sorted: $relative" >&2
        exit 1
    fi
    source_path="$root/src/cser/$relative"
    target_path="/kernel/nexus-ostd/src/cser/$relative"
    if [[ ! -f $source_path || -L $source_path ]] \
        || [[ $(realpath -e -- "$source_path") != "$source_path" ]]; then
        echo "CSER production source must be a non-symlink regular file: $source_path" >&2
        exit 1
    fi
    cser_source_hash_inputs+=("$source_path")
    cser_source_mount_args+=(--mount "type=bind,source=$source_path,target=$target_path,readonly")
    previous_production_source=$relative
done
if ((${#cser_production_sources[@]} == 0)); then
    echo "CSER production source manifest is empty" >&2
    exit 1
fi
readonly production_source_manifest
readonly -a cser_production_sources cser_source_hash_inputs cser_source_mount_args
# Hash only inputs consumed while building the pinned image. Runtime serial

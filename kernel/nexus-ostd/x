    "$root/scripts/assert-runtime-net-artifacts.sh" \
    "$root/guest/linux-futex-shared.S" \
    "$root/guest/linux-futex-personality-v1.S" \
    "$root/guest/linux-futex-personality-v2.S" \
    "$root/guest/linux-dynamic-personality-v1.S" \
    "$root/guest/linux-dynamic-personality-v2.S" \
    "$root/guest/linux-futex-core-personality-v1.S" \
    "$root/guest/linux-futex-core-personality-v2.S" \
    "$root/guest/linux-netd-v1.S" \
    "$root/guest/linux-netd-v2.S" \
    "$root/src/evaluation/stage7b.rs" \
    "$root/userspace/personality/.cargo/config.toml" \
    "$root/userspace/personality/Cargo.toml" \
    "$root/userspace/personality/Cargo.lock" \
    "$root/userspace/personality/linker.ld" \
    "$root/userspace/personality/src/bin/v1.rs" \
    "$root/userspace/personality/src/bin/v2.rs" \
    "$repo_root/crates/cser-transition-gates/Cargo.toml" \
    "$repo_root/crates/cser-transition-gates/src/lib.rs" \
    "$repo_root/crates/cser-transition-gates/src/oneshot.rs" \
    "$repo_root/crates/cser-transition-gates/src/deadline.rs" \
    "$repo_root/crates/cser-transition-gates/src/scheduler.rs" \
    "$repo_root/crates/cser-transition-gates/src/pager.rs" \
    "$repo_root/crates/cser-transition-gates/src/io.rs" \
    "$repo_root/crates/nexus-ostd-virtio/Cargo.toml" \
    "$repo_root/crates/nexus-ostd-virtio/Cargo.lock" \
